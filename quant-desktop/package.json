{
  "name": "stock-quant-desktop",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm --prefix ../quant-web run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "~5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.stockquant.pro",
    "productName": "Stock Quant Pro",
    "files": [
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "../quant-web/dist",
        "to": "web"
      }
    ]
  }
}
