{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockquant.local/schemas/agent-team-request.schema.json",
  "title": "Stock Quant Pro Agent Team Analysis Request",
  "description": "Read-only Java-to-Python request for POST /agents/team/analyze.",
  "type": "object",
  "required": [
    "schemaVersion", "taskId", "runIds", "symbol", "tradeDate", "contextHash",
    "contextSchemaVersion", "ruleVersion", "executionMode", "contextSnapshot", "requestedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "taskId": { "type": "integer", "minimum": 1 },
    "runIds": {
      "type": "object",
      "required": [
        "dataQuality", "marketRegime", "technicalAnalysis", "strategyBacktest",
        "announcementRisk", "positionRisk"
      ],
      "properties": {
        "dataQuality": { "type": "integer", "minimum": 1 },
        "marketRegime": { "type": "integer", "minimum": 1 },
        "technicalAnalysis": { "type": "integer", "minimum": 1 },
        "strategyBacktest": { "type": "integer", "minimum": 1 },
        "announcementRisk": { "type": "integer", "minimum": 1 },
        "positionRisk": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "symbol": { "type": "string", "pattern": "^[0-9]{6}$" },
    "tradeDate": { "type": "string", "format": "date" },
    "contextHash": { "$ref": "agent-output.schema.json#/$defs/sha256" },
    "contextSchemaVersion": { "type": "string", "minLength": 1 },
    "ruleVersion": { "type": "string", "minLength": 1 },
    "executionMode": { "$ref": "agent-output.schema.json#/$defs/executionMode" },
    "contextSnapshot": {
      "type": "object",
      "description": "Immutable read-only context generated by Java. It must not contain account, order or trade mutation commands.",
      "required": [
        "security", "marketData", "marketBreadth", "scanResult", "technicalMetrics",
        "backtestContext", "securityEvents", "portfolioContext", "dataQualityContext"
      ],
      "properties": {
        "security": { "$ref": "#/$defs/extensibleContext" },
        "marketData": { "$ref": "#/$defs/extensibleContext" },
        "marketBreadth": { "$ref": "#/$defs/extensibleContext" },
        "scanResult": { "$ref": "#/$defs/extensibleContext" },
        "technicalMetrics": { "$ref": "#/$defs/extensibleContext" },
        "backtestContext": { "$ref": "#/$defs/extensibleContext" },
        "securityEvents": { "$ref": "#/$defs/extensibleContext" },
        "portfolioContext": { "$ref": "#/$defs/extensibleContext" },
        "dataQualityContext": { "$ref": "#/$defs/extensibleContext" }
      },
      "additionalProperties": true
    },
    "requestedAt": { "$ref": "agent-output.schema.json#/$defs/dateTimeWithZone" }
  },
  "additionalProperties": false,
  "$defs": {
    "extensibleContext": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
