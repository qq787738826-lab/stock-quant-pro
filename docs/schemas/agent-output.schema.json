{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockquant.local/schemas/agent-output.schema.json",
  "title": "Stock Quant Pro Agent Output",
  "description": "Structured output for one of the six professional agent executions. Chief decisions use agent-decision.schema.json instead.",
  "type": "object",
  "required": [
    "schemaVersion", "taskId", "runId", "agentCode", "status", "gateStatus",
    "decision", "veto", "score", "confidence", "summary", "findings",
    "evidence", "errors", "contextHash", "ruleVersion", "executionMode", "generatedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "taskId": { "type": "integer", "minimum": 1 },
    "runId": { "type": "integer", "minimum": 1 },
    "agentCode": { "$ref": "#/$defs/agentCode" },
    "status": { "$ref": "#/$defs/status" },
    "gateStatus": { "$ref": "#/$defs/gateStatus" },
    "decision": { "$ref": "#/$defs/agentDecision" },
    "veto": { "type": "boolean" },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "evidence": {
      "type": "array",
      "description": "Evidence subset produced or used by this agent. The team response top-level evidence array is authoritative.",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    },
    "contextHash": { "$ref": "#/$defs/sha256" },
    "ruleVersion": { "type": "string", "minLength": 1 },
    "executionMode": { "$ref": "#/$defs/executionMode" },
    "generatedAt": { "$ref": "#/$defs/dateTimeWithZone" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "agentCode": { "const": "POSITION_RISK" } },
        "required": ["agentCode"]
      },
      "then": true,
      "else": {
        "properties": { "veto": { "const": false } }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "agentCode": {
      "type": "string",
      "enum": [
        "DATA_QUALITY", "MARKET_REGIME", "TECHNICAL_ANALYSIS", "STRATEGY_BACKTEST",
        "ANNOUNCEMENT_RISK", "POSITION_RISK"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETED", "PARTIAL", "INSUFFICIENT_DATA", "FAILED"]
    },
    "gateStatus": {
      "type": "string",
      "enum": ["PASS", "WARN", "BLOCKED", "NOT_APPLICABLE"]
    },
    "agentDecision": {
      "type": "string",
      "enum": ["PASS", "WARN", "REJECT", "NOT_APPLICABLE"]
    },
    "executionMode": {
      "type": "string",
      "const": "LOCAL_RULES"
    },
    "severity": {
      "type": "string",
      "enum": ["INFO", "WARN", "HIGH", "CRITICAL"]
    },
    "finding": {
      "type": "object",
      "required": ["findingId", "code", "severity", "title", "detail", "evidenceIds"],
      "properties": {
        "findingId": { "type": "string", "minLength": 1 },
        "code": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "title": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidenceId", "category", "sourceType", "sourceName", "sourceRef", "symbol",
        "tradeDate", "observedAt", "collectedAt", "fields", "contentHash"
      ],
      "properties": {
        "evidenceId": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "MARKET_DATA", "MARKET_BREADTH", "TECHNICAL_INDICATOR", "SCAN_RESULT",
            "BACKTEST_RESULT", "SECURITY_EVENT", "PORTFOLIO_STATE", "DATA_QUALITY", "QUERY_RESULT"
          ]
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "DATABASE", "LOCAL_CACHE", "CONFIGURED_PROVIDER", "JAVA_ENGINE", "PYTHON_RULE_ENGINE"
          ]
        },
        "sourceName": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string", "minLength": 1 },
        "symbol": { "type": "string", "pattern": "^(?:[0-9]{6})?$" },
        "tradeDate": { "type": "string", "format": "date" },
        "observedAt": { "$ref": "#/$defs/dateTimeWithZone" },
        "collectedAt": { "$ref": "#/$defs/dateTimeWithZone" },
        "fields": { "type": "object", "minProperties": 1, "additionalProperties": true },
        "contentHash": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dateTimeWithZone": {
      "type": "string",
      "format": "date-time",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    }
  }
}
